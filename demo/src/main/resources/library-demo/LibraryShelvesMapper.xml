<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="reengineering.ddd.demo.library.mybatis.mappers.LibraryShelvesMapper">
  <resultMap id="shelf" type="reengineering.ddd.demo.library.model.Shelf">
    <id property="identity" column="id" jdbcType="BIGINT" javaType="String"/>
    <association property="description"
                 javaType="reengineering.ddd.demo.library.description.ShelfDescription">
      <constructor>
        <arg column="name" jdbcType="VARCHAR" javaType="String"/>
      </constructor>
    </association>
    <association property="books"
                 javaType="reengineering.ddd.demo.library.mybatis.ShelfBooks">
      <result column="id" property="shelfId" javaType="int"/>
    </association>
  </resultMap>
</mapper>
